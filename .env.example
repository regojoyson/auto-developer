# ─── Secrets Only ─────────────────────────────────────
# All other config lives in config.yaml.
# Project IDs and owner/repo are auto-detected from git remote URLs.

# Jira (when config.yaml issueTracker.type = jira)
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=

# GitHub Issues (when config.yaml issueTracker.type = github-issues)
# Uses the same GITHUB_TOKEN as the git provider below.
GITHUB_OWNER=

# GitLab (when config.yaml gitProvider.type = gitlab)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# GitHub (when config.yaml gitProvider.type = github)
GITHUB_TOKEN=
