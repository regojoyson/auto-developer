# ─── Secrets Only ─────────────────────────────────────
# All other config lives in config.yaml.
# Project IDs and owner/repo are auto-detected from git remote URLs.

# GitLab (when config.yaml gitProvider.type = gitlab)
GITLAB_BASE_URL=https://gitlab.com
GITLAB_TOKEN=

# GitHub (when config.yaml gitProvider.type = github)
GITHUB_TOKEN=
